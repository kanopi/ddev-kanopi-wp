#!/usr/bin/env bash
#ddev-generated

## Description: Runs NPM commands on the theme.
## Usage: theme-npm [flags] [args]
## Example: ddev theme-npm install
##          ddev theme-npm run build
## Aliases: theme:npm

set -e

source /var/www/html/.ddev/scripts/load-config.sh
load_kanopi_config

if [ -n "${THEME:-}" ]; then
    FULL_THEME_PATH=$(get_full_theme_path)
    if [ -d "${FULL_THEME_PATH}" ]; then
        cd "${FULL_THEME_PATH}"
        npm "$@"
    else
        echo "Theme directory not found: ${FULL_THEME_PATH}"
        echo "Please ensure your theme is located at the correct path or update THEME environment variable in .ddev/config.yaml"
        exit 1
    fi
else
    npm "$@"
fi
