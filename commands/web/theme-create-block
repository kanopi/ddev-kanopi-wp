#!/usr/bin/env bash

## Description: Create a new WordPress block
## Usage: theme-create-block <block-name>
## Example: "ddev theme-create-block my-awesome-block"
## Aliases: create-block,thcb,theme:create-block

#ddev-generated

set -e

if [ -z "$1" ]; then
    echo "Usage: ddev theme-create-block <block-name>"
    exit 1
fi

source /var/www/html/.ddev/scripts/load-config.sh
load_kanopi_config

BLOCK_NAME="$1"
BLOCKS_PATH="$(get_full_theme_path)/assets/src/blocks"

# "todo-list" -> "Todo List"
FORMATTED_BLOCK_TITLE=$(echo "$BLOCK_NAME" | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++)$i=toupper(substr($i,1,1)) tolower(substr($i,2))}1')
echo "Formatted Block Title: $FORMATTED_BLOCK_TITLE"

TEMPLATE_BLOCK_DIR="/var/www/html/.ddev/config/wp/block-template"
NEW_BLOCK_DIR="${BLOCKS_PATH}/${BLOCK_NAME}"

if [ ! -d "$TEMPLATE_BLOCK_DIR" ]; then
    echo "Template block directory does not exist: $TEMPLATE_BLOCK_DIR"
    exit 1
fi

if [ -d "$NEW_BLOCK_DIR" ]; then
    echo "Block directory already exists: $NEW_BLOCK_DIR"
    exit 1
fi

mkdir -p "$BLOCKS_PATH"
rsync -av --exclude=".*" "$TEMPLATE_BLOCK_DIR/" "$NEW_BLOCK_DIR/"

# Rename files containing 'example-block' in their basename.
find "$NEW_BLOCK_DIR" -name '*example-block*' | while read -r FILE; do
    NEW_FILE=$(echo "$FILE" | sed "s/example-block/${BLOCK_NAME}/g")
    mv "$FILE" "$NEW_FILE"
done

# Single sed pass per file: strip the ddev-generated signature lines AND
# substitute block name + title. Previously this was three separate
# find+loop traversals.
find "$NEW_BLOCK_DIR" -type f | while read -r FILE; do
    case "$FILE" in
        *.json)
            sed -i \
                -e '/^[[:space:]]*"#ddev-generated":.*,$/d' \
                -e "s/example-block/${BLOCK_NAME}/g" \
                -e "s/Name of Block/${FORMATTED_BLOCK_TITLE}/g" \
                "$FILE"
            ;;
        *.js)
            sed -i \
                -e '/^[[:space:]]*\*[[:space:]]*#ddev-generated/d' \
                -e '/^[[:space:]]*\*[[:space:]]*$/d' \
                -e "s/example-block/${BLOCK_NAME}/g" \
                -e "s/Name of Block/${FORMATTED_BLOCK_TITLE}/g" \
                "$FILE"
            ;;
        *.scss)
            sed -i \
                -e '/^\/\*[[:space:]]*#ddev-generated.*\*\/$/d' \
                -e "s/example-block/${BLOCK_NAME}/g" \
                -e "s/Name of Block/${FORMATTED_BLOCK_TITLE}/g" \
                "$FILE"
            ;;
        *)
            sed -i \
                -e "s/example-block/${BLOCK_NAME}/g" \
                -e "s/Name of Block/${FORMATTED_BLOCK_TITLE}/g" \
                "$FILE"
            ;;
    esac
done

echo "Block created successfully at: ${NEW_BLOCK_DIR}"
echo "Run 'ddev theme-watch' to start the development server and begin working on your block."
