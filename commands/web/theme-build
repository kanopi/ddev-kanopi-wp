#!/usr/bin/env bash

## Description: Build production assets for the theme
## Usage: theme-build
## Example: "ddev theme-build"
## Aliases: production,theme:build,thb,theme-production

#ddev-generated

set -e

source /var/www/html/.ddev/scripts/load-config.sh
load_kanopi_config

THEME_PATH=$(get_full_theme_path)

if [ ! -d "$THEME_PATH" ]; then
    echo "Theme directory not found: $THEME_PATH"
    echo "Please ensure your theme is located at the correct path or update THEME environment variable in .ddev/config.yaml"
    exit 1
fi

if [ ! -f "$THEME_PATH/package.json" ]; then
    echo "package.json not found in theme directory: $THEME_PATH"
    echo "Please ensure your theme has a package.json file with npm scripts configured"
    exit 1
fi

echo "Building production assets for theme at: $THEME_PATH"
cd "$THEME_PATH"

if [ ! -d "node_modules" ]; then
    echo "Installing npm dependencies..."
    if [ -f package-lock.json ] || [ -f npm-shrinkwrap.json ]; then
        npm ci --prefer-offline --no-audit --no-fund --loglevel=warn
    else
        npm install --prefer-offline --no-audit --no-fund --loglevel=warn
    fi
fi

npm run build

echo "Production build completed successfully!"
