#!/usr/bin/env bash
#ddev-generated

## Refresh DB
## Description: Downloads the database from the hosting provider. Supports Pantheon, WPEngine, Kinsta, and Remote SSH platforms.
## Usage: db-refresh [environment id]
## Example: ddev db-refresh pr-123
## Aliases: refresh,db:refresh
## Flags: [{"Name":"force","Shorthand":"f","Usage":"Force creation of new backup regardless of age"}]

set -e

# Colors / divider / emojis come from load-config.sh.
source /var/www/html/.ddev/scripts/load-config.sh
user_command='ddev wp-restore-admin-user'
load_kanopi_config

# Resolve default environment per provider.
case "${HOSTING_PROVIDER}" in
    pantheon) DEFAULT_ENV="dev" ;;
    wpengine) DEFAULT_ENV="${HOSTING_SITE}" ;;
    kinsta)   DEFAULT_ENV="live" ;;
    remote)   DEFAULT_ENV="" ;;
    *)        DEFAULT_ENV="dev" ;;
esac
ENVIRONMENT="${HOSTING_ENV:-$DEFAULT_ENV}"

FORCE_BACKUP=false
for arg in "$@"; do
    case $arg in
        --force|-f)
            FORCE_BACKUP=true
            shift
            ;;
        *)
            if [ "$arg" != "2" ] && [ -z "${ENVIRONMENT_SET:-}" ]; then
                ENVIRONMENT="$arg"
                ENVIRONMENT_SET=true
            fi
            shift
            ;;
    esac
done

cd "${DDEV_APPROOT}"

# Per-provider required config check.
case "${HOSTING_PROVIDER}" in
    pantheon|wpengine)
        REQUIRED_VARS="HOSTING_SITE"
        ;;
    kinsta)
        REQUIRED_VARS="REMOTE_HOST"
        ;;
    remote)
        REQUIRED_VARS="REMOTE_HOST REMOTE_DOMAIN"
        ;;
    *)
        REQUIRED_VARS="HOSTING_SITE"
        ;;
esac
for v in $REQUIRED_VARS; do
    if [ -z "${!v:-}" ]; then
        echo -e "${red}Error: ${v} not configured for ${HOSTING_PROVIDER}. Run 'ddev project-configure'.${NC}"
        exit 1
    fi
done

echo -e "\n${yellow}Refreshing database from ${HOSTING_PROVIDER} environment: ${ENVIRONMENT}${NC}"

case "${HOSTING_PROVIDER}" in
    pantheon|wpengine|kinsta)
        REFRESH_SCRIPT=".ddev/scripts/refresh-${HOSTING_PROVIDER}.sh"
        REFRESH_ARG="$ENVIRONMENT"
        ;;
    remote)
        REFRESH_SCRIPT=".ddev/scripts/refresh-remote.sh"
        REFRESH_ARG=""
        ;;
    *)
        echo -e "${red}Hosting platform '$HOSTING_PROVIDER' not supported${NC}"
        echo -e "${yellow}Supported platforms: pantheon, wpengine, kinsta, remote${NC}"
        exit 1
        ;;
esac

echo -e "${green}Using ${HOSTING_PROVIDER} refresh script...${NC}"
if ! bash "$REFRESH_SCRIPT" "$REFRESH_ARG" "$FORCE_BACKUP"; then
    echo -e "${red}Database refresh failed. Please check the error messages above.${NC}"
    exit 1
fi

echo -e "\n${yellow}Running post-refresh cleanup and setup...${NC}"

cd "$(get_docroot_path)"

# Combine the wp-cli post-refresh commands into a single shell pipeline so the
# CLI bootstraps once rather than three times.
wp cache flush --allow-root 2>/dev/null || true
wp rewrite flush --allow-root
wp plugin deactivate wp-health ithemes-security-pro autoptimize --allow-root --quiet 2>/dev/null || true

echo -e "\n${green}Database refresh completed successfully!${NC}"
echo -e "\n${yellow}Please run: ${green}${user_command}${NC} ${yellow}to load the admin user.${NC}"
