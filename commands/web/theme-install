#!/usr/bin/env bash
#ddev-generated

## Description: Install and set up theme development tools in DDEV
## Usage: theme-install
## Example: ddev theme-install
## Aliases: install-theme-tools,thi,theme:install

set -e

# Colors / divider / emojis come from load-config.sh.
source /var/www/html/.ddev/scripts/load-config.sh
watch_command='ddev theme:watch'
load_kanopi_config

FULL_THEME_PATH=$(get_full_theme_path)

echo -e "\n ${shark} ${yellow} Installing theme development tools. ${NC} ${shark}\n"
echo -e "${green}${divider}${NC}"

echo -e "\n ${rocket} ${yellow} Navigating to theme directory: ${FULL_THEME_PATH} ${NC} ${rocket}"
echo -e "${green}${divider}${NC}"

if [ ! -d "${FULL_THEME_PATH}" ]; then
    echo -e "\n${yellow}Theme directory not found: ${FULL_THEME_PATH}${NC}"
    echo -e "Please ensure your theme is located at the correct path or update THEME environment variable in .ddev/config.yaml"
    exit 1
fi

cd "${FULL_THEME_PATH}"

echo -e "\n ${construction} ${yellow} Installing NPM dependencies. ${NC} ${construction}"
echo -e "${green}${divider}${NC}"

# Only source nvm once per shell.
if [ -z "${NVM_DIR:-}" ]; then
    export NVM_DIR="$HOME/.nvm"
    # shellcheck source=/dev/null
    source "$NVM_DIR/nvm.sh"
fi
echo "NVM version: $(nvm --version)"

if [ -f "${FULL_THEME_PATH}/.nvmrc" ]; then
    NODE_VERSION=$(cat "${FULL_THEME_PATH}/.nvmrc")
    echo "Using Node.js version: ${NODE_VERSION}"
    nvm install "${NODE_VERSION}"
    nvm alias default "${NODE_VERSION}"
    nvm use
else
    echo "No .nvmrc found, using default Node version"
    nvm use default || nvm use node
fi

# Prefer `npm ci` when a lockfile is present (faster, reproducible).
if [ -f package-lock.json ] || [ -f npm-shrinkwrap.json ]; then
    npm ci --prefer-offline --no-audit --no-fund --loglevel=warn
else
    npm install --prefer-offline --no-audit --no-fund --loglevel=warn --save patch-package
fi

echo -e "\n ${construction} ${yellow} Compiling theme assets. ${NC} ${construction}"
echo -e "${green}${divider}${NC}"
npm run build

echo -e "\n ${party} ${yellow} Theme setup complete! ${NC} ${reverseparty}"
echo -e "To start watching for file changes, run: ${yellow}${watch_command}${NC}"
echo -e "${green}${divider}${NC}"
