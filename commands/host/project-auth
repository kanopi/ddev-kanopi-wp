#!/usr/bin/env bash

## Description: Authorizes you into DDEV.
## Usage: project-auth
## Example: "ddev project-auth"
## Aliases: project:auth

#ddev-generated

set -e

# Load configuration to check hosting provider
source .ddev/scripts/load-config.sh
load_kanopi_config

# Expand a path that may begin with ~ to an absolute path on the host.
# Stays here (not in load-config.sh) because the web container doesn't have
# the user's $HOME and never needs to resolve ~/.ssh paths.
expand_ssh_key_path() {
    local raw="$1"
    if [[ "$raw" =~ ^\~/ ]]; then
        echo "$HOME/${raw:2}"
    elif [[ "$raw" =~ ^\~$ ]]; then
        echo "$HOME"
    else
        echo "$raw"
    fi
}

if [[ "${HOSTING_PROVIDER}" == "wpengine" ]]; then
    # ddev's container can't read the user's .ssh; pull the configured key name
    # from the project's config.yaml on the host instead.
    WPENGINE_SSH_KEY=$(ddev utility configyaml --full-yaml 2>/dev/null \
      | docker run -i --rm ddev/ddev-utilities yq '.web_environment[] | select(contains("WPENGINE_SSH_KEY")) | sub("WPENGINE_SSH_KEY=","")')
    echo "🔍 WPEngine detected - using specific SSH key: $WPENGINE_SSH_KEY"

    SSH_KEY_PATH=$(expand_ssh_key_path "$WPENGINE_SSH_KEY")
    SSH_KEY_PATH="${SSH_KEY_PATH%.pub}"

    echo "   Resolved to: $SSH_KEY_PATH"

    if [ ! -f "$SSH_KEY_PATH" ]; then
        echo "⚠️  SSH key not found on host: $SSH_KEY_PATH"
        echo "   Debugging information:"
        echo "   - Original path: $WPENGINE_SSH_KEY"
        echo "   - Resolved path: $SSH_KEY_PATH"
        echo "   - Files in ~/.ssh/:"
        ls -la ~/.ssh/ 2>/dev/null | grep "$(basename "$SSH_KEY_PATH")" || echo "   Key file not found"
        echo ""
        echo "   Please check your WPENGINE_SSH_KEY configuration"
        echo "   Run 'ddev project-configure' to update it"
        echo ""
        echo "⚠️  For WPEngine, only the specific SSH key can be loaded."
        exit 1
    fi

    echo "✅ SSH key file found on host"
    echo "🔑 Adding WPEngine SSH key to container..."
    KEY_NAME=$(basename "$SSH_KEY_PATH")
    # Single ddev exec chain: prepare ~/.ssh, copy the key in, set perms, ssh-add.
    cat "$SSH_KEY_PATH" | ddev exec "mkdir -p ~/.ssh && chmod 700 ~/.ssh && cat > ~/.ssh/$KEY_NAME && chmod 600 ~/.ssh/$KEY_NAME && ssh-add ~/.ssh/$KEY_NAME"

    echo "✅ Loaded only WPEngine SSH key: $KEY_NAME"
else
    echo "Loading all SSH keys for $HOSTING_PROVIDER"
    ddev auth ssh
fi
