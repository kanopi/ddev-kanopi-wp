#!/usr/bin/env bash

## Description: Install & WordPress if needed.
## Usage: project-wp
## Example: "ddev project-wp"
## Aliases: project:wp

#ddev-generated

# Colors / divider / emojis come from load-config.sh.

# Load configuration to get hosting provider
source .ddev/scripts/load-config.sh
load_kanopi_config

# resolve_host_docroot returns inherited DOCROOT immediately when set
# (project-init exports it); falls back to ddev's merged config otherwise.
DOCROOT=$(resolve_host_docroot)

case "${HOSTING_PROVIDER}" in
    "pantheon" | "wpengine")
        DOCROOT="${DOCROOT:-web}"
        if [ "$DOCROOT" = "." ] || [ -z "$DOCROOT" ]; then
            DOCROOT=""
        fi
        ;;
    "kinsta")
        DOCROOT="public"
        ;;
    *)
        DOCROOT="${DOCROOT:-web}"
        ;;
esac

echo "Using docroot: $DOCROOT for hosting provider: $HOSTING_PROVIDER"
DOCROOT_PATH="/var/www/html/${DOCROOT}"
LOCAL_PATH="${DOCROOT:-.}"

# Single check for an existing WordPress core in either the docroot or public/.
wp_core_present() {
    [ -f "${LOCAL_PATH}/index.php" ] && [ -f "${LOCAL_PATH}/wp-load.php" ] && return 0
    [ -f "public/wp-config-sample.php" ] && return 0
    [ -f "public/index.php" ] && return 0
    return 1
}

if wp_core_present; then
    CORE_CHECK_PASSED="true"
else
    CORE_CHECK_PASSED="false"
fi

# Install WordPress core if needed
if [ "$CORE_CHECK_PASSED" = "false" ]; then
  echo -e "\n${construction} ${yellow} Installing WordPress core...${NC} ${construction}\n"
  echo -e "${green}${divider}${NC}"
  ddev exec "wp core download --path=${DOCROOT_PATH} --allow-root"

  # Only create config if it doesn't exist
  if [ ! -f "${LOCAL_PATH}/wp-config.php" ] && [ ! -f "${LOCAL_PATH}/wp-config-ddev.php" ]; then
    echo "📝 Creating WordPress configuration file..."
    ddev exec "wp config create --dbname=db --dbuser=db --dbpass=db --dbhost=db --path=${DOCROOT_PATH} --dbprefix='${WP_PREFIX:-wp_}' --allow-root"
  fi
else
  echo "📝 WordPress core files found in docroot: ${LOCAL_PATH}"
fi

# Re-check after potential install above.
if wp_core_present; then
  # Check if WordPress database is installed
  echo "📝 Checking WordPress database installation status..."

  # Use a more robust check for WordPress installation
  if ddev exec "wp core is-installed --path=${DOCROOT_PATH} --allow-root" >/dev/null 2>&1; then
    echo "✅ WordPress database is already installed"
  else
    echo "📝 WordPress database is not installed"
    echo -e "\n${construction} ${yellow} Setting up WordPress database...${NC} ${construction}\n"
    echo -e "${green}${divider}${NC}"

    # Make sure wp-config.php exists first
    if [ ! -f "${LOCAL_PATH}/wp-config.php" ] && [ ! -f "${LOCAL_PATH}/wp-config-ddev.php" ]; then
      echo "📝 Creating WordPress configuration file..."
      ddev exec "wp config create --dbname=db --dbuser=db --dbpass=db --dbhost=db --path=${DOCROOT_PATH} --dbprefix='${WP_PREFIX:-wp_}' --allow-root"
    fi

    # Install WordPress
    echo "📝 Installing WordPress database tables..."
    INSTALL_RESULT=$(ddev exec "wp core install --url=\$DDEV_PRIMARY_URL --title='WordPress Site' --admin_user=admin --admin_password=admin --admin_email=admin@example.com --path=${DOCROOT_PATH} --allow-root" 2>&1)
    INSTALL_EXIT_CODE=$?

    if [ $INSTALL_EXIT_CODE -eq 0 ] && echo "$INSTALL_RESULT" | grep -q "Success"; then
      echo "✅ WordPress database installed successfully"
    elif echo "$INSTALL_RESULT" | grep -q "already installed"; then
      echo "✅ WordPress database was already configured"
    else
      echo "⚠️  WordPress database installation had issues:"
      echo "   Exit code: $INSTALL_EXIT_CODE"
      echo "   Output: $INSTALL_RESULT"
    fi
  fi
else
  echo "⚠️  WordPress core files not found - please check your composer setup"
  echo "   Expected location: ${LOCAL_PATH}/"
  echo "   Alternate location checked: public/"
fi
