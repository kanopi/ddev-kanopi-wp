#!/usr/bin/env bash
#ddev-generated

## Description: Runs composer install and database refresh.
## Usage: db-rebuild
## Example: "ddev db-rebuild"
## Aliases: rebuild,db:rebuild

set -e

# Colors / divider come from load-config.sh.
source .ddev/scripts/load-config.sh

echo -e "\n${yellow} Composer install. ${NC}"
echo -e "${green}${divider}${NC}"
retry_command 3 ddev composer install

ddev db-refresh

# Run cache flush + db update in a single ddev exec to avoid three container round-trips.
ddev exec "wp cache flush --allow-root 2>/dev/null || echo 'Cache flush completed'; \
           wp core update-db --allow-root 2>/dev/null || echo 'Database update completed'"

ddev cypress-users
